<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NANZO PANEL - COORDINATE CONFIG</title>
    <style>
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            background-color: #0f172a; 
            color: white; 
            text-align: center; 
            padding: 40px; 
        }
        .container { 
            background: #1e293b; 
            padding: 30px; 
            border-radius: 20px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.5); 
            display: inline-block; 
            max-width: 400px; 
            width: 100%;
            border: 1px solid #334155; 
            text-align: left;
        }
        h1 { 
            color: #38bdf8; 
            margin-bottom: 5px; 
            text-align: center;
            font-size: 24px;
        }
        .subtitle {
            color: #94a3b8;
            text-align: center;
            margin-bottom: 25px;
            font-size: 14px;
        }
        .checkbox-group {
            background: #0f172a;
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 12px;
            border: 1px solid #334155;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .checkbox-group:hover {
            border-color: #38bdf8;
            background: #1e293b;
        }
        .label-text {
            font-weight: 600;
            color: #e2e8f0;
        }
        .sub-label {
            display: block;
            font-size: 12px;
            color: #94a3b8;
            font-weight: normal;
            margin-top: 2px;
        }
        /* Custom Switch Button */
        .switch {
            position: relative;
            display: inline-block;
            width: 44px;
            height: 24px;
        }
        .switch input { 
            opacity: 0;
            width: 0;
            height: 0;
        }
        .slider {
            position: absolute;
            cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: #475569;
            transition: .3s;
            border-radius: 24px;
        }
        .slider:before {
            position: absolute;
            content: "";
            height: 16px;
            width: 16px;
            left: 4px;
            bottom: 4px;
            background-color: white;
            transition: .3s;
            border-radius: 50%;
        }
        input:checked + .slider {
            background-color: #38bdf8;
        }
        input:checked + .slider:before {
            transform: translateX(20px);
        }
        .btn { 
            display: block; 
            text-align: center;
            margin-top: 25px; 
            padding: 14px; 
            background: #38bdf8; 
            color: #0f172a; 
            text-decoration: none; 
            border-radius: 8px; 
            font-weight: bold; 
            border: none;
            width: 100%;
            font-size: 16px;
            cursor: pointer;
            transition: background 0.3s ease, transform 0.2s ease; 
        }
        .btn:hover {
            background: #0ea5e9;
            transform: translateY(-2px);
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>NANZO PANEL v1.0</h1>
        <div class="subtitle">3D Vector Head Pointer Configuration</div>

        <!-- Head X Switch -->
        <label class="checkbox-group">
            <div>
                <span class="label-text">Lock HeadX</span>
                <span class="sub-label">Sumbu Horisontal (Kiri / Kanan)</span>
            </div>
            <div class="switch">
                <input type="checkbox" id="headX">
                <span class="slider"></span>
            </div>
        </label>

        <!-- Head Y Switch -->
        <label class="checkbox-group">
            <div>
                <span class="label-text">Lock HeadY (Auto HS)</span>
                <span class="sub-label">Sumbu Vertikal (Atas / Bawah)</span>
            </div>
            <div class="switch">
                <input type="checkbox" id="headY">
                <span class="slider"></span>
            </div>
        </label>

        <!-- Head Z Switch -->
        <label class="checkbox-group">
            <div>
                <span class="label-text">Lock HeadZ</span>
                <span class="sub-label">Sumbu Kedalaman (Jarak Ruang)</span>
            </div>
            <div class="switch">
                <input type="checkbox" id="headZ">
                <span class="slider"></span>
            </div>
        </label>

        <button class="btn" onclick="injectCoordinates()">Inject Selected Memory</button>
    </div>

    <script>
        function injectCoordinates() {
            let xActive = document.getElementById('headX').checked;
            let yActive = document.getElementById('headY').checked;
            let zActive = document.getElementById('headZ').checked;

            if(!xActive && !yActive && !zActive) {
                alert("Silakan pilih minimal satu sumbu koordinat untuk di-inject!");
                return;
            }

            let statusMessage = "=== INJECTION LOG ===\n";
            if(xActive) statusMessage += "• Memory.Write[HeadX] -> OK (Horizontal Locked)\n";
            if(yActive) statusMessage += "• Memory.Write[HeadY] -> OK (Vertical/Auto HS Locked)\n";
            if(zActive) statusMessage += "• Memory.Write[HeadZ] -> OK (Depth/Distance Locked)\n";

            alert(statusMessage + "\nStatus: Sumbu koordinat berhasil dikunci pada memori sistem.");
        }
    </script>

</body>
</html>
